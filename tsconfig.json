import axios from 'axios';

export function getApiErrorMessage(error: unknown, fallback = 'Notika negaidīta kļūda.'): string {
  if (axios.isAxiosError(error)) {
    if (error.code === 'ECONNABORTED') {
      return 'Pieprasījums aizņēma pārāk ilgu laiku. Mēģini vēlreiz.';
    }

    if (!error.response) {
      return 'Nevar izveidot savienojumu ar serveri. Pārliecinies, ka json-server darbojas uz porta 3001.';
    }

    if (error.response.status >= 500) {
      return 'Servera kļūda. Mēģini vēlreiz pēc brīža.';
    }

    if (error.response.status === 404) {
      return 'Pieprasītie dati netika atrasti.';
    }
  }

  return fallback;
}
